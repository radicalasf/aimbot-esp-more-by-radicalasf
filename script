    TargetPart     = "Head",
    AimSmooth      = 0.15,
    FOVRadius      = 150,
    TeamCheck      = false,

    -- Chams
    ChamsEnabled   = false,
    WallTint       = true,

    -- 2-D ESP
    BoxESP         = false,
    NameESP        = false,
    TracerESP      = false,
    HealthBarESP   = false,
